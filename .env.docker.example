# Copy to `.env` (git-ignored) for `docker compose up`. Do NOT commit real secrets.

# Image tag to run (matches what scripts/docker-build-push.sh pushed).
TAG=latest

# Host port the app is published on (the SPA + proxied /api live here).
WEB_PORT=8080

# REQUIRED. JWT signing secret — the API refuses to start if empty.
# Generate one with: openssl rand -base64 48
JWT_SIGNING_KEY=

# REQUIRED. Server-side password pepper for Argon2id hashing. Must be valid
# Base64 (it is Base64-decoded at startup) — generate with: openssl rand -base64 32
# WARNING: changing this after accounts exist invalidates every stored password.
AUTH_PEPPER=

# REQUIRED on first run. Password for the seeded "admin" account.
ADMIN_PASSWORD=

# Optional web-push (VAPID). Leave empty to disable push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# PWA install gate. When true, the app is usable only as an installed PWA — a
# normal browser tab gets the install guide instead. Set true to enforce PWA-only
# (recommended once everyone has installed). Devs bypass with ?debug=doener.
PWA_GATE_ENABLED=false
